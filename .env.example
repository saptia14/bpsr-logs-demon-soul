# Copy to .env for local development. None of these are required to RUN the app
# (it is plug-and-play); they only affect signed release builds and the optional
# BPTimer integration. The real .env is git-ignored.

# Tauri updater signing (only needed to produce auto-updatable release builds).
# Generate a keypair with: bun tauri signer generate -w ~/.tauri/myapp.key
# The matching PUBLIC key must be set as `plugins.updater.pubkey` in tauri.conf.json.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Optional BPTimer integration (world-boss/magical-creature HP reporting).
# Leave blank to disable. See artifacts/Documentation.md §14.
BP_TIMER_ENDPOINT=
BP_TIMER_API_KEY=
